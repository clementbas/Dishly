meta {
  name: Refresh Token
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/api/auth/refresh
  body: json
  auth: none
}

body:json {
  {
    "refreshToken": "{{refreshToken}}"
  }
}

script:post-response {
  if (res.body.success) {
    bru.setEnvVar("token", res.body.data.accessToken);
    bru.setEnvVar("refreshToken", res.body.data.refreshToken);
  }
}
